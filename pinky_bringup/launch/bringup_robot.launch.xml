<?xml version='1.0' ?>

<launch>
    <arg name="namespace" default=""/>
    <arg name="use_sim_time" default="False"/> 
    <arg name="wheel_radius" default="0.027"/>
    <arg name="wheel_separation" default="0.0961"/>
    <arg name="odom_frame_id" default="odom"/>
    <arg name="base_frame_id" default="base_footprint"/>
    <arg name="left_joint_name" default="l_wheel_joint"/>
    <arg name="right_joint_name" default="r_wheel_joint"/>

    <include file="$(find-pkg-share pinky_description)/launch/upload_robot.launch.py">
        <arg name="namespace" value="$(var namespace)"/>
        <arg name="use_sim_time" value="$(var use_sim_time)"/>
    </include>

    <group>
        <push-ros-namespace namespace="$(var namespace)"/>

        <include file="$(find-pkg-share sllidar_ros2)/launch/sllidar_c1_launch.py">
            <arg name="serial_port" value="/dev/ttyS0"/>
            <arg name="frame_id" value="rplidar_link"/>
            <arg name="inverted" value="false"/>
            <arg name="angle_compensate" value="true"/>
            <arg name="scan_mode" value="DenseBoost"/>
        </include>

        <node pkg="pinky_bringup" exec="bringup">
            <param from="$(find-pkg-share pinky_bringup)/config/pinky_params.yaml"/>
            <param name="wheel_radius" value="$(var wheel_radius)"/>
            <param name="wheel_separation" value="$(var wheel_separation)"/>
            <param name="odom_frame_id" value="$(var odom_frame_id)"/>
            <param name="base_frame_id" value="$(var base_frame_id)"/>
            <param name="left_joint_name" value="$(var left_joint_name)"/>
            <param name="right_joint_name" value="$(var right_joint_name)"/>

            <remap from="/tf" to="tf"/>
            <remap from="/tf_static" to="tf_static"/>
        </node>
        
        <node pkg="pinky_bringup" exec="battery_publisher">
        </node>
    </group>
    
</launch>
